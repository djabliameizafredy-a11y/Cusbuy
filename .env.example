# ================================================================
# CUSBUY - Configuration des API Keys
# Copier ce fichier en .env et remplir avec vos vraies clés
# NE JAMAIS committer le fichier .env sur GitHub !
# ================================================================

# ------- GEMINI / FIREBASE AI -------
# Récupérer sur: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ------- AGORA.IO (Live Streaming) -------
# 1. Créer un compte sur https://www.agora.io
# 2. Créer un projet dans la console Agora
# 3. Copier l'App ID ici
AGORA_APP_ID=YOUR_AGORA_APP_ID

# ------- GOOGLE MAPS -------
# 1. Aller sur https://console.cloud.google.com
# 2. Activer "Maps SDK for Android"
# 3. Créer une clé API
MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ------- CLOUDFLARE STREAM (Upload Vidéo CDN) -------
# 1. Créer un compte Cloudflare: https://www.cloudflare.com
# 2. Activer Stream dans ton dashboard
# 3. API Token > Créer un token avec permission Stream
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN

# ------- FIREBASE -------
# NE PAS mettre les clés Firebase ici !
# Télécharger google-services.json depuis la console Firebase
# et le placer dans: app/google-services.json
# https://console.firebase.google.com
